<Title>:
    Label:
        font_size:50
        center_x: root.width/2
        top: root.top - 20 
        text: "Screen Time Buddy"

<SlidingStringSetting>:
    orientation: 'vertical'
    padding: 20
    
    TabbedPanel:
        do_default_tab: False
        tab_pos: 'top_mid' 

        TabbedPanelItem:
            markup: True
            text: '[b]Acknowledge[/b]' if self.state == 'down' else 'Acknowledge'
            on_release: root.on_button_press()
            Label:
                text: 'Pop up requiring you to acknowledge.'

        TabbedPanelItem:
            markup: True
            text: '[b]Blocking[/b]' if self.state == 'down' else 'Blocking'
            on_release: root.on_button_press()
            Label:
                text: 'Blocks screen and activity forcing a break.'

        TabbedPanelItem:
            markup: True
            text: "[b]Notification[/b] "if self.state == 'down' else 'Notification'
            on_release: root.on_button_press()
            Label:
                text: 'Alert at temporarily displays at top or on side, can be ignored.'
        
      
    